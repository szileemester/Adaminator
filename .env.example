# Copy to .env and adjust for your environment. Used by docker compose.
# Do NOT commit the real .env file.

# PostgreSQL password (shared by the db and api services).
POSTGRES_PASSWORD=adaminator

# Single admin password used to sign in to the admin area.
ADMIN_PASSWORD=adaminator-dev

# JWT signing key (must be long and secret in real deployments).
JWT_KEY=dev-only-change-me-adaminator-signing-key-1234567890
